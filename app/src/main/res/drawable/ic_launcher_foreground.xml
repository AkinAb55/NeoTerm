<?xml version="1.0" encoding="utf-8"?>
<!-- NeoTerm adaptive icon foreground: a bold terminal prompt ">_" — white
     chevron + neon-green cursor block, with a soft drop shadow for depth.
     Content stays within the centre safe zone. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Drop shadow (offset copy underneath) -->
    <group android:translateX="1.5" android:translateY="2.5">
        <path
            android:strokeColor="#33000000"
            android:strokeWidth="9"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M34,40 L52,54 L34,68" />
        <path
            android:fillColor="#33000000"
            android:pathData="M58.5,62 H75.5 A2.5,2.5 0 0 1 78,64.5 V69.5 A2.5,2.5 0 0 1 75.5,72 H58.5 A2.5,2.5 0 0 1 56,69.5 V64.5 A2.5,2.5 0 0 1 58.5,62 Z" />
    </group>

    <!-- Prompt chevron -->
    <path
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="9"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M34,40 L52,54 L34,68" />

    <!-- Cursor block (neon accent) -->
    <path
        android:pathData="M58.5,62 H75.5 A2.5,2.5 0 0 1 78,64.5 V69.5 A2.5,2.5 0 0 1 75.5,72 H58.5 A2.5,2.5 0 0 1 56,69.5 V64.5 A2.5,2.5 0 0 1 58.5,62 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="56" android:startY="62"
                android:endX="78" android:endY="72">
                <item android:offset="0" android:color="#FF2AF598" />
                <item android:offset="1" android:color="#FF1FD1B2" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
