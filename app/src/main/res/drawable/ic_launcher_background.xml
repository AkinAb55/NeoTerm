<?xml version="1.0" encoding="utf-8"?>
<!-- NeoTerm adaptive icon background: vivid purple→blue gradient with a neon
     glow behind the prompt and a soft top-left sheen. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base diagonal gradient -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="6" android:startY="0"
                android:endX="102" android:endY="108">
                <item android:offset="0" android:color="#FF6A11CB" />
                <item android:offset="0.55" android:color="#FF3A46D9" />
                <item android:offset="1" android:color="#FF2575FC" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Neon glow behind the centred prompt -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54" android:centerY="58"
                android:gradientRadius="46">
                <item android:offset="0" android:color="#662AF598" />
                <item android:offset="1" android:color="#002AF598" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Top-left sheen -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="26" android:centerY="20"
                android:gradientRadius="64">
                <item android:offset="0" android:color="#33FFFFFF" />
                <item android:offset="1" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
